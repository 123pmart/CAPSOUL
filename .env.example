# Required in production for signed admin sessions.
CAPSOUL_SESSION_SECRET=replace-with-a-long-random-secret

# Required in production for admin login, leads, content, and media metadata.
# The app does not fall back to local JSON/files on Vercel production.
# You can use any one of these:
# - CAPSOUL_DATABASE_URL
# - POSTGRES_URL
# - DATABASE_URL
CAPSOUL_DATABASE_URL=postgres://user:password@host:5432/database

# Required for production media uploads/replacements via Vercel Blob.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Optional bootstrap override for the first seeded admin password.
# If omitted, the initial password defaults to: password
CAPSOUL_INITIAL_ADMIN_PASSWORD=password
